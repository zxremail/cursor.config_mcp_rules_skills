#!/usr/bin/env bash
# Markdown 目录补充 CLI 入口
# Python >= 3.7 → md-toc.py；否则 → md-toc-batch.py（3.5/3.6 兼容）
set -e
DIR="$(dirname "$(readlink -f "$0" 2>/dev/null || echo "$0")")"
PY=python3

# 无参数：处理当前目录所有 .md
if [ "$#" -eq 0 ]; then
  shopt -s nullglob
  files=(*.md)
  shopt -u nullglob
  if [ "${#files[@]}" -eq 0 ]; then
    echo "md-toc: 当前目录未找到 .md 文件" >&2
    exit 1
  fi
  set -- "${files[@]}"
fi

if "$PY" -c 'import sys; sys.exit(0 if sys.version_info[:2] >= (3, 7) else 1)' 2>/dev/null; then
  exec "$PY" "$DIR/md-toc.py" "$@"
else
  exec "$PY" "$DIR/md-toc-batch.py" "$@"
fi
